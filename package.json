{
	"name": "pi-caido",
	"version": "0.1.1",
	"description": "Drive Caido from pi — send requests through the Repeater, search HTTP history with HTTPQL, route scanners through the proxy, and keep every byte of CTF / pentest traffic in one place.",
	"type": "module",
	"keywords": [
		"pi-package",
		"caido",
		"pi",
		"security",
		"ctf",
		"pentest",
		"web",
		"proxy",
		"httpql",
		"automation",
		"repeater"
	],
	"license": "MIT",
	"author": "not-narleeek",
	"homepage": "https://github.com/not-narleeek/pi-caido",
	"repository": {
		"type": "git",
		"url": "https://github.com/not-narleeek/pi-caido.git"
	},
	"bugs": {
		"url": "https://github.com/not-narleeek/pi-caido/issues"
	},
	"files": [
		"extensions",
		"scripts",
		"docs",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./extensions/caido.ts"
		]
	},
	"scripts": {
		"clean": "rm -rf node_modules dist",
		"check": "tsc --noEmit -p tsconfig.json",
		"py-check": "python3 -m py_compile scripts/caido.py && echo 'caido.py: syntax OK'"
	},
	"devDependencies": {
		"@types/node": "^22.20.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"peerDependenciesMeta": {
		"@earendil-works/pi-ai": {
			"optional": false
		},
		"@earendil-works/pi-coding-agent": {
			"optional": false
		},
		"@earendil-works/pi-tui": {
			"optional": false
		},
		"typebox": {
			"optional": false
		}
	},
	"engines": {
		"node": ">=18"
	}
}
